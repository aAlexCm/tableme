{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/fr", "destination": "/index" },
    { "source": "/en", "destination": "/index" },
    { "source": "/ro", "destination": "/index" },
    { "source": "/guest/fr", "destination": "/guest" },
    { "source": "/guest/en", "destination": "/guest" },
    { "source": "/guest/ro", "destination": "/guest" },
    { "source": "/rsvp/fr", "destination": "/rsvp" },
    { "source": "/rsvp/en", "destination": "/rsvp" },
    { "source": "/rsvp/ro", "destination": "/rsvp" }
  ]
}
