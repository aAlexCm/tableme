rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Google sign-in alone only proves "this is some Google account" — it
    // does not prove it's the app owner. This is the actual access control:
    // only these emails are treated as superadmin. Add more emails here
    // (comma-separated) if someone else also needs the admin panels.
    function isSuperAdmin() {
      return request.auth != null &&
        request.auth.token.email in ['boagiualexandru@gmail.com'];
    }

    // Couples and their guests reach a specific wedding only via its link
    // (?id=...), with no login at all — so a single wedding doc must stay
    // readable/writable without auth. What must NOT stay open is dumping the
    // whole collection, or creating/deleting weddings — those only happen
    // from the superadmin panel (admin.html), which now requires sign-in.
    match /weddings/{weddingId} {
      allow get, update: if true;
      allow list, create, delete: if isSuperAdmin();
    }

    // Partners are shown to every guest on the partners page, so reads stay
    // public. Only the superadmin panel (partners-admin.html) creates,
    // edits, reorders, or deletes partners.
    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Any guest browsing can log a click (anonymous, write-only). Viewing
    // the aggregated stats is superadmin-only.
    match /partnerClicks/{clickId} {
      allow create: if true;
      allow read: if isSuperAdmin();
    }

    // Couples and guests both run JS that can fail (a Firestore write
    // rejected, an unhandled exception) — they need to report that without
    // any auth, the same as partnerClicks above. Only the superadmin panel
    // reads or clears the log.
    match /appLogs/{logId} {
      allow create: if true;
      allow read, delete: if isSuperAdmin();
    }
  }
}
